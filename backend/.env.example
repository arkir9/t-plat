# ============================================
# T-Plat Backend Environment Configuration
# ============================================
# Copy this file to .env and update with your actual credentials
# NEVER commit .env file to version control

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
# Use postgres (or a DB user you created). Do NOT use your OS username.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=t_plat
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Database Connection Pooling (for scalability)
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY=3000
DB_CACHE_DURATION=30000

# ============================================
# JWT Authentication Configuration
# ============================================
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=change-this-to-a-random-refresh-secret-key-in-production
JWT_REFRESH_EXPIRATION=30d

# ============================================
# Payment Configuration
# ============================================

# Stripe (Card Payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# M-Pesa (Safaricom Daraja API - Kenya)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_SHORTCODE=your_mpesa_shortcode_here
MPESA_PASSKEY=your_mpesa_passkey_here
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/mpesa/callback

# ============================================
# Cloudinary (Image Storage)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# Email Configuration (SendGrid)
# ============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
EMAIL_FROM=noreply@tplat.com
EMAIL_NAME=T-Plat

# ============================================
# Firebase (Push Notifications)
# ============================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Firebase Private Key Here\n-----END PRIVATE KEY-----\n"

# ============================================
# Google Maps API
# ============================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# OpenAI (AI Event Extraction)
# ============================================
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# App Configuration
# ============================================
FRONTEND_URL=http://localhost:3001
MOBILE_APP_URL=tplat://
APP_NAME=T-Plat

# ============================================
# Security & Rate Limiting
# ============================================
CORS_ORIGIN=http://localhost:3001,http://localhost:19006
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
REQUEST_TIMEOUT=30000

# HMAC secret for signing ticket QR codes (generate with: openssl rand -hex 32)
QR_HMAC_SECRET=change-this-to-a-random-hex-secret-in-production

# ============================================
# Cache Configuration (Optional - Redis)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# SMS Configuration (Optional - Twilio/African SMS)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ============================================
# AI Event Extraction (OpenAI)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Notes
# ============================================
# 1. Generate JWT secrets using:
#    openssl rand -base64 32
#    OR
#    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# 2. Get Stripe keys from: https://dashboard.stripe.com/apikeys
#
# 3. Get M-Pesa credentials from Safaricom Daraja API portal
#
# 4. Get Cloudinary credentials from: https://cloudinary.com/
#
# 5. Get SendGrid API key from: https://app.sendgrid.com/settings/api_keys
#
# 6. Get Firebase credentials from: https://console.firebase.google.com/
#
# 7. Get Google Maps API key from: https://console.cloud.google.com/
