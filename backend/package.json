{
    "name": "t-plat-backend",
    "version": "0.1.0",
    "description": "T-Plat Backend API - Nightlife & Event Ticketing Platform",
    "author": "T-Plat Team",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "node run-dev.js",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "typeorm": "typeorm-ts-node-commonjs",
        "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/typeorm.config.ts",
        "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/typeorm.config.ts",
        "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/typeorm.config.ts",
        "create:env": "chmod +x scripts/create-env.sh && ./scripts/create-env.sh",
        "setup:env": "chmod +x scripts/setup-env.sh && ./scripts/setup-env.sh",
        "setup:env:win": "powershell -ExecutionPolicy Bypass -File scripts/setup-env.ps1",
        "db:setup": "chmod +x scripts/complete-setup.sh && ./scripts/complete-setup.sh",
        "db:setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup-db.ps1",
        "db:create": "chmod +x scripts/create-database.sh && ./scripts/create-database.sh",
        "db:drop": "psql -h ${DB_HOST:-localhost} -p ${DB_PORT:-5432} -U ${DB_USERNAME:-postgres} -d postgres -c \"DROP DATABASE IF EXISTS ${DB_DATABASE:-t_plat};\"",
        "db:schema": "chmod +x scripts/run-schema.sh && ./scripts/run-schema.sh",
        "db:verify": "chmod +x scripts/verify-db.sh && ./scripts/verify-db.sh",
        "db:fix-user": "chmod +x scripts/fix-db-user.sh && ./scripts/fix-db-user.sh",
        "db:update-username": "chmod +x scripts/update-db-username.sh && ./scripts/update-db-username.sh",
        "check:env": "chmod +x scripts/check-env.sh && ./scripts/check-env.sh",
        "seed:events": "ts-node -r tsconfig-paths/register scripts/seed-events.ts",
        "seed:events:sql": "node scripts/seed-events-sql.js"
    },
    "dependencies": {
        "@nestjs/axios": "^3.0.1",
        "@nestjs/cache-manager": "^2.1.1",
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^3.1.1",
        "@nestjs/core": "^10.3.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.3.0",
        "@nestjs/schedule": "^4.0.0",
        "@nestjs/swagger": "^7.1.17",
        "@nestjs/terminus": "^10.1.1",
        "@nestjs/throttler": "^5.0.1",
        "@nestjs/typeorm": "^10.0.1",
        "bcrypt": "^5.1.1",
        "cache-manager": "^5.3.2",
        "cache-manager-redis-store": "^3.0.1",
        "bullmq": "^4.0.0",
        "cheerio": "^1.2.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "cloudinary": "^1.41.0",
        "compression": "^1.7.4",
        "dotenv": "^16.3.1",
        "express-rate-limit": "^7.1.5",
        "firebase-admin": "^12.0.0",
        "google-auth-library": "^9.4.1",
        "helmet": "^7.1.0",
        "jose": "^5.2.0",
        "nodemailer": "^6.9.7",
        "playwright": "^1.49.0",
        "openai": "^6.25.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.11.3",
        "qrcode": "^1.5.3",
        "reflect-metadata": "^0.1.14",
        "rxjs": "^7.8.1",
        "stripe": "^14.9.0",
        "tsconfig-paths": "^4.2.0",
        "typeorm": "^0.3.17",
        "uuid": "^9.0.1",
        "zod": "^4.3.6",
        "ioredis": "^4.28.5"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.2.1",
        "@nestjs/schematics": "^10.0.3",
        "@nestjs/testing": "^10.3.0",
        "@swc/core": "^1.15.17",
        "@swc/jest": "^0.2.39",
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.7.5",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.10.6",
        "@types/nodemailer": "^6.4.14",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/qrcode": "^1.5.5",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^9.0.7",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.2",
        "jest": "^29.7.0",
        "prettier": "^3.1.1",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}
